  ],
  "author": "weizhixin",
  "repository": {
    "type": "git",
    "url": "https://github.com/weizhixin14/vue2-draggable-multi.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.5",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "rollup": "^4.40.0",
    "sortablejs": "^1.15.6"
  }
}
