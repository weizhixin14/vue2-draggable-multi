{
  "name": "vue2-draggable-multi",
  "version": "1.0.2",
  "description": "Vue 2 draggable component with multi-drag support based on SortableJS",
  "type": "module",
  "main": "dist/vue2-draggable-multi.cjs.js",
  "module": "dist/vue2-draggable-multi.esm.js",
  "unpkg": "dist/vue2-draggable-multi.umd.min.js",
  "files": [
    "dist",
    "package.json",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w"
  },
  "peerDependencies": {
    "vue": ">=2.6.12 <3",
    "sortablejs": "^1.15.0"
  },
  "keywords": [
